@inherits LayoutComponentBase
@inject Services.CartService Cart
@inject NavigationManager Nav

<div class="app-shell">
    <!-- NAVBAR -->
    <header class="top-navbar">
        <div class="navbar-inner">
            <!-- Logo -->
            <a href="/" class="nav-brand">
                <div class="nav-logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#FF6B00" viewBox="0 0 24 24">
                        <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zm-.5 1.5l1.96 2.5H17V9.5h2.5zM6 18c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm13.5-1c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1z"/>
                    </svg>
                </div>
                <div class="nav-brand-text">
                    <span class="nav-brand-top">TODO PARA TU</span>
                    <span class="nav-brand-bottom">TRACTOCAMIÓN</span>
                </div>
            </a>

            <!-- Nav Links (center) -->
            <nav class="nav-links">
                <a href="/" class="nav-link-item">CATÁLOGO</a>
                <a href="/carrito" class="nav-link-item">CONTACTO</a>
            </nav>

            <!-- Right side: phone + cart -->
            <div class="nav-right">
                <a href="tel:5512345678" class="nav-phone">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#FF6B00" viewBox="0 0 24 24">
                        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                    </svg>
                    55 1234 5678
                </a>
                <button class="nav-cart-btn" @onclick="GoToCart" title="Ver carrito">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" viewBox="0 0 24 24">
                        <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-1.99.9-1.99 2S15.9 22 17 22s2-.9 2-2-.9-2-2-2zm-9.83-3.25l.03-.12.9-1.63H15.55c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 20 4H5.21l-.94-2H1v2h2l3.6 7.59-1.35 2.44C4.52 15.37 5.48 17 7 17h12v-2H7.42c-.14 0-.25-.11-.25-.25z"/>
                    </svg>
                    @if (ItemCount > 0)
                    {
                        <span class="nav-cart-badge">@ItemCount</span>
                    }
                </button>
            </div>
        </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="app-main">
        @Body
    </main>
</div>

@code {
    private int ItemCount => Cart.GetItems().Sum(i => i.Cantidad);

    protected override void OnInitialized()
    {
        Cart.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
    }

    private void GoToCart() => Nav.NavigateTo("/carrito");
}
